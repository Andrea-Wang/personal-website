---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('novel');
entries.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const categories = ['世界观', '人物', '地理', '历史', '势力', '其他'];

function entriesByCategory(cat: string) {
  return entries.filter(e => e.data.category === cat);
}
---

<Layout>
  <main class="page-main">
    <div style="margin-bottom: 0.75rem;">
      <a href="/writing/" style="font-size:0.88rem; color:#6b7280; font-weight:500;">← 写作</a>
    </div>

    <section style="margin-bottom: 2rem;">
      <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:0;">
        <h1 style="font-size: 2.8rem; font-weight: 800; line-height: 1.1; margin: 0; letter-spacing: -0.03em;">设定集</h1>
        <a href="/writing/lore/search/" style="display:inline-flex; align-items:center; gap:0.45rem; padding:0.5rem 1.1rem; background:rgba(255,255,255,0.75); backdrop-filter:blur(12px); border:1px solid rgba(0,0,0,0.09); border-radius:9999px; font-size:0.875rem; font-weight:500; color:#6b7280; text-decoration:none; transition:border-color 0.15s, color 0.15s;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          搜索设定集
        </a>
      </div>
    </section>

    {entries.length === 0 ? (
      <div class="card" style="text-align:center; color:#6b7280; padding: 3rem;">
        设定文档整理中，敬请期待。
      </div>
    ) : (
      <section style="display: grid; gap: 2.5rem;">
        {categories.map(cat => {
          const group = entriesByCategory(cat);
          if (group.length === 0) return null;
          return (
            <div>
              <h2 style="font-size:0.8rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#6b7280; margin:0 0 1rem;">{cat}</h2>
              <div style="display: grid; gap: 0.75rem;">
                {group.map(entry => (
                  <a href={`/writing/lore/${entry.id}/`} class="card" style="text-decoration:none; color:inherit; display:flex; justify-content:space-between; align-items:center; gap:1rem; padding:1.1rem 1.5rem;">
                    <div>
                      <div style="font-weight:600; font-size:1rem; margin-bottom:0.25rem;">{entry.data.title}</div>
                      {entry.data.description && (
                        <div style="font-size:0.85rem; color:#6b7280; line-height:1.6;">{entry.data.description}</div>
                      )}
                    </div>
                    <span style="color:#9ca3af; flex-shrink:0;">→</span>
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </section>
    )}
  </main>
</Layout>
