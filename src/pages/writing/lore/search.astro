---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="搜索设定集 | 汪宸">
  <main class="page-main" data-pagefind-ignore>
    <div style="margin-bottom: 0.75rem;">
      <a href="/writing/lore/" style="font-size:0.88rem; color:#6b7280; font-weight:500;">← 设定集</a>
    </div>

    <section style="margin-bottom: 2.5rem;">
      <h1 style="font-size:2.8rem; font-weight:800; line-height:1.1; margin:0 0 0.5rem; letter-spacing:-0.03em;">搜索</h1>
      <p style="color:#6b7280; font-size:0.95rem; margin:0;">在设定集中搜索世界观、人物、历史等内容。</p>
    </section>

    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <div id="search" style="margin-bottom:2rem;"></div>

    <style>
      .pagefind-ui__search-input {
        background: rgba(255,255,255,0.82) !important;
        border: 1px solid rgba(0,0,0,0.10) !important;
        border-radius: 0.75rem !important;
        font-size: 1rem !important;
        padding: 0.75rem 1rem !important;
        width: 100% !important;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05) !important;
        font-family: inherit !important;
      }
      .pagefind-ui__search-input:focus {
        outline: none !important;
        border-color: rgba(99,102,241,0.4) !important;
        box-shadow: 0 0 0 3px rgba(99,102,241,0.12) !important;
      }
      .pagefind-ui__result {
        background: rgba(255,255,255,0.82) !important;
        border: 1px solid rgba(0,0,0,0.07) !important;
        border-radius: 1rem !important;
        padding: 1.25rem 1.5rem !important;
        margin-bottom: 0.75rem !important;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05) !important;
      }
      .pagefind-ui__result-link {
        color: #111827 !important;
        font-weight: 600 !important;
        font-size: 1rem !important;
        text-decoration: none !important;
      }
      .pagefind-ui__result-link:hover { color: #6366f1 !important; }
      .pagefind-ui__result-excerpt { color: #6b7280 !important; font-size:0.88rem !important; margin-top:0.4rem !important; line-height:1.7 !important; }
      mark { background: rgba(99,102,241,0.15) !important; color: #4338ca !important; border-radius: 0.2rem; padding: 0 0.1em; }
      .pagefind-ui__search-clear, .pagefind-ui__message { color: #6b7280 !important; font-size:0.88rem !important; }
      .pagefind-ui__button {
        background: rgba(99,102,241,0.10) !important;
        color: #6366f1 !important;
        border: 1px solid rgba(99,102,241,0.20) !important;
        border-radius: 9999px !important;
        font-size: 0.88rem !important;
        font-weight: 500 !important;
        padding: 0.5rem 1.25rem !important;
      }
    </style>

    <script src="/pagefind/pagefind-ui.js" type="text/javascript"></script>
    <script>
      window.addEventListener('DOMContentLoaded', () => {
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          translations: {
            placeholder: '搜索设定集内容……',
            zero_results: '没有找到"[SEARCH_TERM]"相关结果',
          }
        });
      });
    </script>
  </main>
</Layout>
