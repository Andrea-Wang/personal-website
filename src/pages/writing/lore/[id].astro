---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('novel');
  return entries.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout>
  <main class="page-main">
    <div style="margin-bottom: 1.5rem; display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
      <a href="/writing/" style="font-size:0.88rem; color:#6b7280; font-weight:500;">写作</a>
      <span style="color:#d1d5db;">›</span>
      <a href="/writing/lore/" style="font-size:0.88rem; color:#6b7280; font-weight:500;">设定集</a>
      <span style="color:#d1d5db;">›</span>
      <span style="font-size:0.88rem; color:#374151;">{entry.data.title}</span>
    </div>

    <div style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.3rem 0.8rem; background:rgba(99,102,241,0.10); border:1px solid rgba(99,102,241,0.18); border-radius:9999px; font-size:0.78rem; font-weight:500; color:#6366f1; margin-bottom:1.75rem;">
      {entry.data.category}
    </div>

    <div class="card" style="max-width:none;">
      <div class="prose">
        <Content />
      </div>
    </div>
  </main>
</Layout>
