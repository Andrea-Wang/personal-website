---
import Layout from '../../layouts/Layout.astro';

const imagePaths = Object.keys(
  import.meta.glob('/public/novel/images/*.{jpg,jpeg,png,gif,webp,svg}')
).map(p => p.replace('/public', ''));
---

<Layout>
  <main class="page-main">
    <div style="margin-bottom: 0.75rem;">
      <a href="/writing/" style="font-size:0.88rem; color:#6b7280; font-weight:500;">← 写作</a>
    </div>

    <section style="margin-bottom: 3rem;">
      <h1 style="font-size: 2.8rem; font-weight: 800; line-height: 1.1; margin: 0 0 1rem; letter-spacing: -0.03em;">设定图</h1>
      <p style="max-width: 680px; color: #6b7280; margin: 0; font-size: 1rem;">
        《阳界：阿斯提摩斯》地图、人物设定图与世界观插图。
      </p>
    </section>

    {imagePaths.length === 0 ? (
      <div class="card" style="text-align:center; padding: 3.5rem 2rem;">
        <div style="font-size:2rem; margin-bottom:1rem;">🖼️</div>
        <p style="color:#6b7280; margin:0; font-size:0.95rem;">
          设定图整理中，敬请期待。<br />
          <span style="font-size:0.82rem; color:#9ca3af;">图片文件放入 <code>public/novel/images/</code> 即可显示。</span>
        </p>
      </div>
    ) : (
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.25rem;">
        {imagePaths.map(src => {
          const label = decodeURIComponent(src.split('/').pop()?.replace(/\.[^.]+$/, '') ?? '');
          return (
            <a href={src} target="_blank" rel="noopener noreferrer" class="card" style="padding:0; overflow:hidden; display:block; text-decoration:none;">
              <img src={src} alt={label} style="width:100%; height:200px; object-fit:cover; display:block;" loading="lazy" />
              <div style="padding:0.65rem 0.9rem; font-size:0.82rem; color:#6b7280; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{label}</div>
            </a>
          );
        })}
      </div>
    )}
  </main>
</Layout>
