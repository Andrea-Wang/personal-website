---
import Layout from '../../layouts/Layout.astro';

const allFiles = import.meta.glob('/public/novel/images/**/*.{jpg,jpeg,png,gif,webp,svg}');

const groups: Record<string, { src: string; name: string }[]> = {};
for (const path of Object.keys(allFiles).sort()) {
  const relative = path.replace('/public/novel/images/', '');
  const parts = relative.split('/');
  if (parts.length < 2) continue;
  const group = decodeURIComponent(parts[0]);
  const name = decodeURIComponent(parts[1].replace(/\.[^.]+$/, ''));
  const src = path.replace('/public', '');
  if (!groups[group]) groups[group] = [];
  groups[group].push({ src, name });
}

const groupEntries = Object.entries(groups);
---

<Layout>
  <main class="page-main">
    <div style="margin-bottom: 0.75rem;">
      <a href="/writing/" style="font-size:0.88rem; color:#6b7280; font-weight:500;">← 写作</a>
    </div>

    <section style="margin-bottom: 3rem;">
      <h1 style="font-size: 2.8rem; font-weight: 800; line-height: 1.1; margin: 0 0 1rem; letter-spacing: -0.03em;">设定图</h1>
      <p style="max-width: 680px; color: #6b7280; margin: 0; font-size: 1rem;">
        《阳界：阿斯提摩斯》人物、地点、徽记与道具设定图。
      </p>
    </section>

    {groupEntries.length === 0 ? (
      <div class="card" style="text-align:center; padding:3.5rem; color:#6b7280;">
        设定图整理中，敬请期待。
      </div>
    ) : (
      <div style="display:grid; gap:3rem;">
        {groupEntries.map(([group, images], gi) => (
          <section class="carousel-section" data-gi={gi}>
            <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:1.25rem; gap:1rem;">
              <h2 style="font-size:1.4rem; font-weight:700; margin:0; letter-spacing:-0.02em;">{group}</h2>
              <div class="carousel-ctrl" style="display:flex; align-items:center; gap:0.6rem; flex-shrink:0;">
                <button class="c-prev" aria-label="上一张" style="width:2rem;height:2rem;border-radius:50%;border:1px solid rgba(0,0,0,0.12);background:rgba(255,255,255,0.8);cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:background 0.15s;">‹</button>
                <span class="c-count" style="font-size:0.85rem; color:#6b7280; min-width:3rem; text-align:center;">1 / {images.length}</span>
                <button class="c-next" aria-label="下一张" style="width:2rem;height:2rem;border-radius:50%;border:1px solid rgba(0,0,0,0.12);background:rgba(255,255,255,0.8);cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:background 0.15s;">›</button>
              </div>
            </div>

            <div class="carousel-viewport" style="overflow:hidden; border-radius:1rem;">
              <div class="carousel-track" style="display:flex; gap:1.25rem; transition:transform 0.32s cubic-bezier(0.4,0,0.2,1);">
                {images.map(img => (
                  <div class="c-item" style="flex:0 0 calc((100% - 2.5rem) / 3); min-width:0;">
                    <a href={img.src} target="_blank" rel="noopener noreferrer" style="display:block; text-decoration:none;">
                      <div style="background:rgba(255,255,255,0.85); border:1px solid rgba(0,0,0,0.07); border-radius:0.85rem; overflow:hidden; aspect-ratio:4/3; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
                        <img
                          src={img.src}
                          alt={img.name}
                          loading="lazy"
                          style="max-width:100%; max-height:100%; object-fit:contain; padding:0.5rem;"
                        />
                      </div>
                      <p style="margin:0.6rem 0 0; font-size:0.88rem; color:#374151; font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{img.name}</p>
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </section>
        ))}
      </div>
    )}
  </main>
</Layout>

<style>
  .c-prev:hover, .c-next:hover { background: rgba(99,102,241,0.10) !important; border-color: rgba(99,102,241,0.3) !important; }
  @media (max-width: 640px) {
    .c-item { flex: 0 0 calc(100% - 0rem) !important; }
  }
  @media (min-width: 641px) and (max-width: 900px) {
    .c-item { flex: 0 0 calc((100% - 1.25rem) / 2) !important; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.carousel-section').forEach(section => {
    const track = section.querySelector<HTMLElement>('.carousel-track')!;
    const items = Array.from(section.querySelectorAll<HTMLElement>('.c-item'));
    const prevBtn = section.querySelector<HTMLButtonElement>('.c-prev')!;
    const nextBtn = section.querySelector<HTMLButtonElement>('.c-next')!;
    const counter = section.querySelector<HTMLElement>('.c-count')!;
    const total = items.length;
    let current = 0;

    function visible() {
      const w = section.clientWidth;
      if (w <= 640) return 1;
      if (w <= 900) return 2;
      return 3;
    }

    function update() {
      const v = visible();
      const max = Math.max(0, total - v);
      current = Math.min(current, max);
      const itemW = items[0]?.offsetWidth ?? 0;
      const gap = 20; // 1.25rem gap
      track.style.transform = `translateX(${-(current * (itemW + gap))}px)`;
      counter.textContent = `${current + 1} / ${total}`;
      prevBtn.style.opacity = current === 0 ? '0.35' : '1';
      nextBtn.style.opacity = current >= max ? '0.35' : '1';
    }

    prevBtn.addEventListener('click', () => { if (current > 0) { current--; update(); } });
    nextBtn.addEventListener('click', () => { if (current < total - visible()) { current++; update(); } });

    window.addEventListener('resize', update);
    requestAnimationFrame(update);
  });
</script>
