---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="page-main">
    <section style="margin-bottom: 3rem;">
      <h1 style="font-size: 2.8rem; font-weight: 800; line-height: 1.1; margin: 0 0 1rem; letter-spacing: -0.03em;">写作</h1>
    </section>

    <section style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 3rem;">
      <a href="/writing/lore/" class="card" style="text-decoration:none; color:inherit; display:block;">
        <div style="width:2rem;height:2rem;border-radius:0.6rem;background:rgba(99,102,241,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:0.9rem;font-size:1rem;">📚</div>
        <h2 style="margin-bottom:0.4rem;">设定集</h2>
        <p style="margin:0; font-size:0.88rem; color:#6b7280; line-height:1.7;">世界观、人物、历史、势力等设定文档。</p>
      </a>
      <a href="/writing/gallery/" class="card" style="text-decoration:none; color:inherit; display:block;">
        <div style="width:2rem;height:2rem;border-radius:0.6rem;background:rgba(168,85,247,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:0.9rem;font-size:1rem;">🖼️</div>
        <h2 style="margin-bottom:0.4rem;">设定图</h2>
        <p style="margin:0; font-size:0.88rem; color:#6b7280; line-height:1.7;">地图、人物设定图与世界观插图。</p>
      </a>
    </section>

    <section>
      <div style="margin-bottom:1.75rem;">
        <h2 style="font-size:1.6rem; font-weight:800; letter-spacing:-0.02em; margin:0 0 0.4rem;">双界编年史</h2>
        <p style="margin:0; font-size:0.9rem; color:#6b7280;">长篇幻想小说系列</p>
      </div>

      <div style="display:grid; gap:1rem;">

        <a href="/writing/part1/" class="card" style="text-decoration:none; color:inherit; display:flex; gap:1.5rem; align-items:center;">
          <div style="flex-shrink:0; width:3.5rem; height:3.5rem; border-radius:0.75rem; background:rgba(99,102,241,0.10); border:1px solid rgba(99,102,241,0.18); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.1rem;">
            <span style="font-size:0.65rem; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#6366f1;">PART</span>
            <span style="font-size:1.3rem; font-weight:800; color:#6366f1; line-height:1;">I</span>
          </div>
          <div style="flex:1; min-width:0;">
            <div style="font-size:0.78rem; font-weight:600; color:#6366f1; margin-bottom:0.25rem; letter-spacing:0.04em;">第一部</div>
            <div style="font-size:1.05rem; font-weight:700; margin-bottom:0.3rem;">阳界·阿斯提摩斯</div>
            <div style="font-size:0.85rem; color:#6b7280; line-height:1.6;">界后 2500 年，从黑松镇到双界真相的旅程。</div>
          </div>
          <div style="flex-shrink:0;">
            <img src="/novel/images/第一部宣传图.png" alt="" style="width:72px; height:72px; object-fit:cover; border-radius:0.6rem; box-shadow:0 2px 8px rgba(0,0,0,0.10);" />
          </div>
        </a>

        <div class="card" style="display:flex; gap:1.5rem; align-items:center; opacity:0.5; cursor:default;">
          <div style="flex-shrink:0; width:3.5rem; height:3.5rem; border-radius:0.75rem; background:rgba(0,0,0,0.05); border:1px solid rgba(0,0,0,0.08); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.1rem;">
            <span style="font-size:0.65rem; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#9ca3af;">PART</span>
            <span style="font-size:1.3rem; font-weight:800; color:#9ca3af; line-height:1;">II</span>
          </div>
          <div style="flex:1; min-width:0;">
            <div style="font-size:0.78rem; font-weight:600; color:#9ca3af; margin-bottom:0.25rem; letter-spacing:0.04em;">第二部</div>
            <div style="font-size:1.05rem; font-weight:700; margin-bottom:0.3rem; color:#9ca3af;">敬请期待</div>
          </div>
        </div>

        <div class="card" style="display:flex; gap:1.5rem; align-items:center; opacity:0.5; cursor:default;">
          <div style="flex-shrink:0; width:3.5rem; height:3.5rem; border-radius:0.75rem; background:rgba(0,0,0,0.05); border:1px solid rgba(0,0,0,0.08); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.1rem;">
            <span style="font-size:0.65rem; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#9ca3af;">PART</span>
            <span style="font-size:1.3rem; font-weight:800; color:#9ca3af; line-height:1;">III</span>
          </div>
          <div style="flex:1; min-width:0;">
            <div style="font-size:0.78rem; font-weight:600; color:#9ca3af; margin-bottom:0.25rem; letter-spacing:0.04em;">第三部</div>
            <div style="font-size:1.05rem; font-weight:700; margin-bottom:0.3rem; color:#9ca3af;">敬请期待</div>
          </div>
        </div>

        <div class="card" style="display:flex; gap:1.5rem; align-items:center; opacity:0.5; cursor:default;">
          <div style="flex-shrink:0; width:3.5rem; height:3.5rem; border-radius:0.75rem; background:rgba(0,0,0,0.05); border:1px solid rgba(0,0,0,0.08); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.1rem;">
            <span style="font-size:0.65rem; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#9ca3af;">PART</span>
            <span style="font-size:1.3rem; font-weight:800; color:#9ca3af; line-height:1;">IV</span>
          </div>
          <div style="flex:1; min-width:0;">
            <div style="font-size:0.78rem; font-weight:600; color:#9ca3af; margin-bottom:0.25rem; letter-spacing:0.04em;">第四部</div>
            <div style="font-size:1.05rem; font-weight:700; margin-bottom:0.3rem; color:#9ca3af;">敬请期待</div>
          </div>
        </div>

      </div>
    </section>
  </main>
</Layout>
