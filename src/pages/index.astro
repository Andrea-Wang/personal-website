---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="page-main">

    <section style="margin-bottom: 4.5rem;">
      <div style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.35rem 0.9rem; background:rgba(99,102,241,0.10); border:1px solid rgba(99,102,241,0.18); border-radius:9999px; font-size:0.8rem; font-weight:500; color:#6366f1; margin-bottom:1.5rem; letter-spacing:0.01em;">
        <span style="width:6px;height:6px;border-radius:50%;background:#6366f1;display:inline-block;box-shadow:0 0 0 2px rgba(99,102,241,0.25);"></span>
        Ph.D. Candidate · Universität Leipzig
      </div>

      <h1 style="font-size: clamp(2.8rem, 7vw, 4rem); font-weight: 800; line-height: 1.05; margin: 0 0 0.4rem; letter-spacing: -0.03em;">汪宸</h1>
      <p style="font-size: 1.25rem; color: #6b7280; font-weight: 400; margin: 0 0 1.5rem; letter-spacing: 0.01em;">Chen Wang</p>

      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center;">
        <a href="/research/" class="btn-primary">研究 →</a>
        <a href="https://github.com/Andrea-Wang" class="btn-secondary" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
        <a href="/about/" class="btn-secondary">关于我</a>
      </div>
    </section>

    <!-- Now -->
    <section style="margin-bottom: 3.5rem;">
      <h2 style="font-size:0.78rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#9ca3af; margin:0 0 1rem;">现在在做</h2>
      <div class="card" style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
        <div>
          <div style="font-size:0.8rem; font-weight:600; letter-spacing:0.05em; text-transform:uppercase; color:#6366f1; margin-bottom:0.6rem;">研究</div>
          <p style="margin:0; font-size:0.92rem; line-height:1.8; color:#374151;">
            在莱比锡大学 Abel 课题组，开展撞击型飞行时间质谱（TOF-MS）实验，
            组装 SELINA 撞击电离平台，并分析土卫二冰羽粒子中的潜在生命信号。
          </p>
        </div>
        <div style="border-left:1px solid rgba(0,0,0,0.07); padding-left:1.5rem;">
          <div style="font-size:0.8rem; font-weight:600; letter-spacing:0.05em; text-transform:uppercase; color:#a855f7; margin-bottom:0.6rem;">写作</div>
          <p style="margin:0; font-size:0.92rem; line-height:1.8; color:#374151;">
            长篇幻想小说《双界编年史》第一部《阳界·阿斯提摩斯》连载中，
            同步整理世界观设定集与人物设定图。
          </p>
        </div>
      </div>
    </section>

    <!-- Featured research -->
    <section>
      <h2 style="font-size:0.78rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#9ca3af; margin:0 0 1rem;">研究方向</h2>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem;">

        <a href="/research/" class="card" style="text-decoration:none; color:inherit; display:block;">
          <div style="width:2.4rem;height:2.4rem;border-radius:0.65rem;background:rgba(99,102,241,0.10);border:1px solid rgba(99,102,241,0.15);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;font-size:1.1rem;">🛰️</div>
          <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.5rem; letter-spacing:-0.01em;">质谱与生命起源</h3>
          <p style="margin:0; font-size:0.88rem; color:#6b7280; line-height:1.75;">
            Orbitrap 高分辨质谱与撞击型 TOF-MS 研究生物分子碎裂机理；
            面向土卫二（Enceladus）冰羽粒子的生命信号分析与生物标志物检测。
          </p>
        </a>

        <a href="/research/" class="card" style="text-decoration:none; color:inherit; display:block;">
          <div style="width:2.4rem;height:2.4rem;border-radius:0.65rem;background:rgba(168,85,247,0.10);border:1px solid rgba(168,85,247,0.15);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;font-size:1.1rem;">✨</div>
          <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.5rem; letter-spacing:-0.01em;">化学发光与光聚合</h3>
          <p style="margin:0; font-size:0.88rem; color:#6b7280; line-height:1.75;">
            化学发光诱导阳离子光聚合体系；DLP/FDM 光固化树脂配方；
            微流控芯片器件制造与化学发光检测集成。
          </p>
        </a>

      </div>
    </section>

  </main>
</Layout>
