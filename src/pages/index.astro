---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="page-main">

    <section style="margin-bottom: 4.5rem;">
      <div style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.35rem 0.9rem; background:rgba(99,102,241,0.10); border:1px solid rgba(99,102,241,0.18); border-radius:9999px; font-size:0.8rem; font-weight:500; color:#6366f1; margin-bottom:1.5rem; letter-spacing:0.01em;">
        <span style="width:6px;height:6px;border-radius:50%;background:#6366f1;display:inline-block;box-shadow:0 0 0 2px rgba(99,102,241,0.25);"></span>
        Ph.D. Candidate · Universität Leipzig
      </div>

      <h1 style="font-size: clamp(2.8rem, 7vw, 4rem); font-weight: 800; line-height: 1.05; margin: 0 0 0.4rem; letter-spacing: -0.03em;">汪宸</h1>
      <p style="font-size: 1.25rem; color: #6b7280; font-weight: 400; margin: 0 0 1.5rem; letter-spacing: 0.01em;">Chen Wang</p>

      <p style="max-width: 680px; color: #374151; font-size: 1.02rem; line-height: 1.85; margin-bottom: 2.25rem;">
        我的研究兴趣包括高分子化学、光聚合反应、化学发光、Orbitrap 质谱与生命起源相关化学问题。
        除科研之外，我也长期进行小说创作，并开发开源工具与科研脚本。
      </p>

      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center;">
        <a href="/research/" class="btn-primary">研究 →</a>
        <a href="https://github.com/Andrea-Wang" class="btn-secondary" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
        <a href="/about/" class="btn-secondary">关于我</a>
      </div>
    </section>

    <section style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem;">
      <a href="/research/" class="card" style="text-decoration:none; color:inherit; display:block;">
        <div style="width:2rem;height:2rem;border-radius:0.6rem;background:rgba(99,102,241,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;font-size:1rem;">⚗️</div>
        <h2>研究</h2>
        <p style="margin:0; font-size:0.92rem; color:#6b7280; line-height:1.75;">
          高分子化学、光聚合、化学发光与 Orbitrap 质谱。整理研究成果与当前工作。
        </p>
      </a>

      <a href="/writing/" class="card" style="text-decoration:none; color:inherit; display:block;">
        <div style="width:2rem;height:2rem;border-radius:0.6rem;background:rgba(168,85,247,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;font-size:1rem;">📖</div>
        <h2>写作</h2>
        <p style="margin:0; font-size:0.92rem; color:#6b7280; line-height:1.75;">
          长篇幻想小说《阳界：阿斯提摩斯》，建立在阳界与阴界相互对应的双界结构之上。
        </p>
      </a>

      <a href="/projects/" class="card" style="text-decoration:none; color:inherit; display:block;">
        <div style="width:2rem;height:2rem;border-radius:0.6rem;background:rgba(56,189,248,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;font-size:1rem;">🔧</div>
        <h2>项目</h2>
        <p style="margin:0; font-size:0.92rem; color:#6b7280; line-height:1.75;">
          开源工具、科研脚本与科学计算相关的实验性项目。
        </p>
      </a>
    </section>

  </main>
</Layout>
